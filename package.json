    "check": "astro check",
    "lh": "unlighthouse --site http://localhost:4321",
    "format": "prettier --write \"src/**/*.{astro,ts,js,md,css}\"",
    "lint": "eslint src --ext .ts,.astro"
  },
  "dependencies": {
