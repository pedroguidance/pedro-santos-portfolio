{
  "name": "pedro-santos-portfolio",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Portfolio of Pedro Santos — Head of Design at Guidance",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 astro dev",
    "build": "astro build",
