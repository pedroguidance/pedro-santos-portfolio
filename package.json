    "@astrojs/mdx": "^4.0.0",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/vercel": "^8.2.11",
    "@google/genai": "^2.6.0",
    "astro": "^5.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "cross-env": "^10.1.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
