---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { src, alt, caption, size = 'md' } = Astro.props;
---

<figure class:list={['iphone-mockup', `size-${size}`]}>
  <div class="iphone-frame">
    <div class="iphone-island" aria-hidden="true"></div>
    <div class="iphone-screen">
      <img src={src} alt={alt} loading="lazy" decoding="async" />
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .iphone-mockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
  }

  /* Frame uses fixed iPhone 16 ratio 9:19.5
     All source images are pre-processed to this ratio,
     so cover never crops content. */
  .iphone-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19.5;
    background: #0e0e10;
    border-radius: 14% / 6.5%;
    padding: 9px;
    box-shadow:
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.05),
      inset 0 0 0 3px rgba(255, 255, 255, 0.02),
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 30px 60px -20px rgba(0, 0, 0, 0.35),
      0 12px 24px -8px rgba(0, 0, 0, 0.18);
  }

  .iphone-island {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 25%;
    height: 22px;
    background: #000;
    border-radius: 100px;
    z-index: 3;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .iphone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 11% / 5%;
    overflow: hidden;
    background: #000;
  }

  .iphone-screen img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background: #000;
  }

  figcaption {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-align: center;
    line-height: 1.45;
    letter-spacing: 0.02em;
    max-width: 24ch;
  }

  /* Size variants */
  .size-sm .iphone-frame { max-width: 220px; }
  .size-md .iphone-frame { max-width: 280px; }
  .size-lg .iphone-frame { max-width: 340px; }

  :global(.mockup-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-lg);
    justify-items: center;
    align-items: start;
    max-width: var(--max-wide);
    margin: var(--space-2xl) auto;
  }

  @media (max-width: 480px) {
    :global(.mockup-grid) {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>
