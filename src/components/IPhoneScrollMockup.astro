---
/**
 * IPhoneScrollMockup — long mobile screen inside an iPhone frame, auto-scrolling.
 *
 * The source image is taller than the iPhone viewport (9:19.5). It's positioned
 * at the top and the track translateY animates from 0 to -(scrollAmount%) and back,
 * like a slow ping-pong, so the viewer sees the entire screen content over time.
 *
 * Respects prefers-reduced-motion: keeps the image at the top, static.
 */
interface Props {
  src: string;
  alt: string;
  caption?: string;
  size?: 'sm' | 'md' | 'lg';
  /** Percent of image height to translate by at peak. Default 60. */
  scrollAmount?: number;
  /** Duration of a one-way scroll trip in seconds. Total cycle = 2x this. */
  duration?: number;
}

const {
  src,
  alt,
  caption,
  size = 'md',
  scrollAmount = 60,
  duration = 18,
} = Astro.props;
---

<figure class:list={['iphone-mockup', `size-${size}`]}>
  <div
    class="iphone-frame"
    style={`--scroll-amount: -${scrollAmount}%; --scroll-duration: ${duration}s;`}
  >
    <div class="iphone-island" aria-hidden="true"></div>
    <div class="iphone-screen">
      <div class="scroll-track">
        <img src={src} alt={alt} loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .iphone-mockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
  }

  .iphone-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19.5;
    background: #0e0e10;
    border-radius: 14% / 6.5%;
    padding: 9px;
    box-shadow:
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.05),
      inset 0 0 0 3px rgba(255, 255, 255, 0.02),
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 30px 60px -20px rgba(0, 0, 0, 0.35),
      0 12px 24px -8px rgba(0, 0, 0, 0.18);
  }

  .iphone-island {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 25%;
    height: 22px;
    background: #000;
    border-radius: 100px;
    z-index: 3;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .iphone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 11% / 5%;
    overflow: hidden;
    background: #000;
  }

  .scroll-track {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    /* track height is the natural image height (auto) */
    will-change: transform;
    animation:
      scroll-vertical var(--scroll-duration, 18s) ease-in-out
      infinite alternate;
  }

  .scroll-track img {
    display: block;
    width: 100%;
    height: auto;
    background: #000;
    user-select: none;
    pointer-events: none;
  }

  @keyframes scroll-vertical {
    from { transform: translateY(0); }
    to   { transform: translateY(var(--scroll-amount, -60%)); }
  }

  /* Pause on hover */
  .iphone-frame:hover .scroll-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-track {
      animation: none;
    }
  }

  figcaption {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-align: center;
    line-height: 1.45;
    letter-spacing: 0.02em;
    max-width: 24ch;
  }

  /* Size variants */
  .size-sm .iphone-frame { max-width: 220px; }
  .size-md .iphone-frame { max-width: 280px; }
  .size-lg .iphone-frame { max-width: 340px; }
</style>
