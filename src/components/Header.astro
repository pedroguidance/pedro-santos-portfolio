---
import { nav } from '~/lib/site-meta';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Pedro Santos. Home">
      <span class="brand-text">
        <span class="brand-first">pedro</span><span class="brand-space"> </span><span class="brand-last">santos</span><span class="brand-dot" aria-hidden="true">.</span>
      </span>
    </a>

    <nav aria-label="Navegação principal">
      <ul class="nav-list">
        {nav.map(item => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <ThemeToggle />
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklch, var(--bg-canvas) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-base) var(--ease-out-quad);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    height: var(--header-height);
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    color: var(--fg-primary);
    transition: color var(--dur-fast) var(--ease-out-quad);
  }

  .brand:hover {
    color: var(--fg-primary);
  }

  .brand:hover .brand-dot {
    transform: translateY(-2px);
  }

  .brand-text {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.015em;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
  }

  .brand-first {
    color: var(--fg-primary);
  }

  .brand-last {
    color: var(--fg-secondary);
  }

  .brand-dot {
    color: var(--accent);
    font-style: normal;
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 0;
    margin-left: 0.05em;
    display: inline-block;
    transition: transform var(--dur-base) var(--ease-out-expo);
    will-change: transform;
  }

  /* Mobile: show only "pedro." to save space */
  .brand-space,
  .brand-last {
    display: none;
  }

  @media (min-width: 480px) {
    .brand-space,
    .brand-last {
      display: inline;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-dot {
      transition: none;
    }
    .brand:hover .brand-dot {
      transform: none;
    }
  }

  .nav-list {
    display: flex;
    gap: var(--space-lg);
    margin: 0;
  }

  .nav-list a {
    color: var(--fg-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--dur-fast) var(--ease-out-quad);
  }

  .nav-list a:hover,
  .nav-list a[aria-current='page'] {
    color: var(--fg-primary);
  }

  @media (max-width: 480px) {
    .nav-list {
      gap: var(--space-md);
    }
  }
</style>
