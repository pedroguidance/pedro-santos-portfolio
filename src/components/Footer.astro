---
import { footerLinks, site } from '~/lib/site-meta';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-row">
      <p class="footer-credit">© {year} · Pedro Santos · Rio de Janeiro</p>

      <ul class="footer-links">
        {footerLinks.map(link => (
          <li>
            <a
              href={link.href}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              target={link.href.startsWith('http') ? '_blank' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <p class="footer-meta">
      Construído com Astro. Tipografia em Fraunces e Inter. Hospedado em Vercel.
      <a href="/decisoes">Decisões</a> de design e execução, documentadas.
    </p>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--space-2xl) var(--space-xl);
    margin-top: var(--space-4xl);
    border-top: 1px solid var(--border);
    background: var(--bg-canvas);
  }

  .footer-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .footer-credit {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin: 0;
  }

  .footer-links a {
    color: var(--fg-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-meta {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--fg-muted);
    max-width: none;
  }
</style>
