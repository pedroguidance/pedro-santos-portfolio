---
interface Screen {
  src: string;
  alt: string;
  label?: string;
}

interface Props {
  screens: Screen[];
  caption?: string;
  size?: 'sm' | 'md' | 'lg';
  /** Duration each screen is visible (ms). Default 3000. */
  duration?: number;
}

const { screens, caption, size = 'md', duration = 3000 } = Astro.props;
const sequenceId = `seq-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class:list={['iphone-mockup', `size-${size}`]}>
  <div class="iphone-frame">
    <div class="iphone-island" aria-hidden="true"></div>
    <div class="iphone-screen" data-sequence-id={sequenceId} data-duration={duration}>
      {screens.map((s, i) => (
        <img
          src={s.src}
          alt={s.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          class:list={['seq-screen', { active: i === 0 }]}
          data-index={i}
        />
      ))}
    </div>
    {screens.length > 1 && (
      <div class="seq-progress" aria-hidden="true">
        {screens.map((_, i) => (
          <span
            class:list={['seq-dot', { active: i === 0 }]}
            data-sequence-dot={sequenceId}
            data-index={i}
          ></span>
        ))}
      </div>
    )}
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .iphone-mockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
  }

  .iphone-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19.5;
    background: #0e0e10;
    border-radius: 14% / 6.5%;
    padding: 9px;
    box-shadow:
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.05),
      inset 0 0 0 3px rgba(255, 255, 255, 0.02),
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 30px 60px -20px rgba(0, 0, 0, 0.35),
      0 12px 24px -8px rgba(0, 0, 0, 0.18);
  }

  .iphone-island {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 25%;
    height: 22px;
    background: #000;
    border-radius: 100px;
    z-index: 3;
  }

  .iphone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 11% / 5%;
    overflow: hidden;
    background: #000;
  }

  .seq-screen {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background: #000;
    opacity: 0;
    transition: opacity 600ms var(--ease-out-quad, ease-out);
    will-change: opacity;
  }

  .seq-screen.active {
    opacity: 1;
  }

  .seq-progress {
    position: absolute;
    bottom: -22px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 4;
  }

  .seq-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border, rgba(0, 0, 0, 0.2));
    transition:
      background var(--dur-fast, 200ms) ease,
      transform var(--dur-fast, 200ms) ease;
  }

  .seq-dot.active {
    background: var(--accent, #1c5238);
    transform: scale(1.4);
  }

  figcaption {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-align: center;
    line-height: 1.45;
    letter-spacing: 0.02em;
    max-width: 28ch;
    margin-top: var(--space-md);
  }

  .size-sm .iphone-frame { max-width: 220px; }
  .size-md .iphone-frame { max-width: 280px; }
  .size-lg .iphone-frame { max-width: 340px; }

  @media (prefers-reduced-motion: reduce) {
    .seq-screen { transition: none; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  const sequences = document.querySelectorAll<HTMLElement>(
    '.iphone-screen[data-sequence-id]',
  );

  sequences.forEach(seq => {
    const id = seq.dataset.sequenceId;
    const duration = parseInt(seq.dataset.duration || '3000', 10);
    const screens = Array.from(
      seq.querySelectorAll<HTMLImageElement>('.seq-screen'),
    );
    const dots = Array.from(
      document.querySelectorAll<HTMLElement>(
        `[data-sequence-dot="${id}"]`,
      ),
    );

    if (screens.length <= 1) return;
    if (reduceMotion) return; // Stay on first screen

    let current = 0;
    let paused = false;

    // Pause on hover (desktop)
    const frame = seq.closest<HTMLElement>('.iphone-frame');
    frame?.addEventListener('mouseenter', () => (paused = true));
    frame?.addEventListener('mouseleave', () => (paused = false));

    // Pause when not in viewport
    let inView = false;
    const io = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          inView = entry.isIntersecting;
        });
      },
      { threshold: 0.4 },
    );
    io.observe(seq);

    function advance() {
      if (paused || !inView) return;
      screens[current]?.classList.remove('active');
      dots[current]?.classList.remove('active');
      current = (current + 1) % screens.length;
      screens[current]?.classList.add('active');
      dots[current]?.classList.add('active');
    }

    setInterval(advance, duration);
  });
</script>
